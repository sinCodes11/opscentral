# OpsCentral Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_PASSWORD=your_secure_password_here

# =============================================================================
# API Security
# =============================================================================
# API key for authenticating requests (generate with: openssl rand -hex 32)
API_KEY=your_api_key_here

# =============================================================================
# OCI Configuration
# =============================================================================
# OCI SDK configuration path (default: ~/.oci)
OCI_CONFIG_PATH=~/.oci

# OCI Tenancy OCID (from OCI Console > Administration > Tenancy Details)
OCI_TENANCY_OCID=ocid1.tenancy.oc1..your_tenancy_ocid

# OCI User OCID (from OCI Console > Identity > Users)
OCI_USER_OCID=ocid1.user.oc1..your_user_ocid

# OCI Compartment OCID for monitoring (from OCI Console > Identity > Compartments)
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..your_compartment_ocid

# OCI Region identifier
OCI_REGION=us-ashburn-1

# =============================================================================
# Grafana Configuration
# =============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here
GRAFANA_ROOT_URL=http://localhost:3000

# =============================================================================
# Application Settings
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Alert collection interval (seconds)
ALERT_COLLECTION_INTERVAL=60

# Metrics collection interval (seconds)
METRICS_COLLECTION_INTERVAL=300

# =============================================================================
# Optional: External SIEM Integration
# =============================================================================
# Splunk HEC endpoint (optional)
# SPLUNK_HEC_URL=https://your-splunk:8088/services/collector
# SPLUNK_HEC_TOKEN=your_hec_token

# =============================================================================
# Optional: Slack Notifications
# =============================================================================
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
